generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  draft
  in_progress
  completed
  cancelled
}

enum SessionTestStatus {
  pending
  completed
  skipped
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamp(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  sessions Session[]

  @@map("users")
}

model Scale {
  id          String   @id @default(uuid()) @db.Uuid
  code        String?  @unique @db.VarChar(30)
  name        String   @db.VarChar(120)
  description String?  @db.Text
  estimatedDurationMin Int? @map("estimated_duration_min")
  metadata    Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  sections ScaleSection[]
  tests    ScaleTest[]
  sessions Session[]

  @@map("scales")
}

model ScaleSection {
  id          String   @id @default(uuid()) @db.Uuid
  scaleId     String   @map("scale_id") @db.Uuid
  name        String   @db.VarChar(120)
  description String?  @db.Text
  orderIndex  Int      @map("order_index")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  scale Scale     @relation(fields: [scaleId], references: [id], onDelete: Cascade)
  tests ScaleTest[]

  @@unique([scaleId, orderIndex])
  @@index([scaleId, isDefault])
  @@map("scale_sections")
}

model ScaleTest {
  id          String   @id @default(uuid()) @db.Uuid
  scaleId     String   @map("scale_id") @db.Uuid
  sectionId   String   @map("section_id") @db.Uuid
  name        String   @db.VarChar(160)
  description String?  @db.Text
  scoreValues String   @map("score_values") @db.Text
  scoreLabels String   @map("score_labels") @db.Text
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  scale   Scale             @relation(fields: [scaleId], references: [id], onDelete: Cascade)
  section ScaleSection      @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  results SessionTestResult[]

  @@unique([scaleId, orderIndex])
  @@index([scaleId, sectionId, orderIndex])
  @@map("scale_tests")
}

model Session {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  patientId       String        @map("patient_id") @db.VarChar(80)
  scaleId         String        @map("scale_id") @db.Uuid
  status          SessionStatus @default(draft)
  startedAt       DateTime?     @map("started_at") @db.Timestamp(6)
  endedAt         DateTime?     @map("ended_at") @db.Timestamp(6)
  generalComments String?       @map("general_comments") @db.Text
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)

  user        User                @relation(fields: [userId], references: [id])
  scale       Scale               @relation(fields: [scaleId], references: [id])
  testResults SessionTestResult[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("sessions")
}

model SessionTestResult {
  id             String            @id @default(uuid()) @db.Uuid
  sessionId      String            @map("session_id") @db.Uuid
  scaleTestId    String            @map("scale_test_id") @db.Uuid
  scoreValue     Decimal?          @map("score_value") @db.Decimal(5, 2)
  notes          String?           @db.Text
  transcriptText String?           @map("transcript_text") @db.Text
  audioUrl       String?           @map("audio_url") @db.Text
  durationSec    Int?              @map("duration_sec")
  status         SessionTestStatus @default(pending)
  orderIndex     Int               @map("order_index")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamp(6)

  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scaleTest ScaleTest @relation(fields: [scaleTestId], references: [id], onDelete: Restrict)

  @@unique([sessionId, scaleTestId])
  @@index([sessionId, orderIndex])
  @@map("session_test_results")
}
